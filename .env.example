# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_CREDENTIALS_PATH=~/.config/gcloud/application_default_credentials.json

# BigQuery
BQ_DATASET=data_sandbox_dev
BQ_LOCATION=US

# GCS
GCS_BUCKET=your-gcp-project-id-raw

# Hex (single-use workspace)
HEX_API_TOKEN=your-hex-api-token
HEX_PROJECT_ID=your-hex-project-id
